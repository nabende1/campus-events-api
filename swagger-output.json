  "definitions": {
    "Event": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "example": "Hackathon 2026"
        },
        "date": {
          "type": "string",
          "example": "2026-05-10"
        },
        "location": {
          "type": "string",
          "example": "Engineering Building"
        },
        "organizerId": {
          "type": "string",
          "example": "6801234567890abcde123456"
        },
        "venueId": {
          "type": "string",
          "example": "6801234567890abcde123466"
        },
        "category": {
          "type": "string",
          "example": "hackathon"
        },
        "startTime": {
          "type": "string",
          "example": "17:30"
        },
        "endTime": {
          "type": "string",
          "example": "20:30"
        },
        "isVirtual": {
          "type": "boolean",
          "example": false
        },
        "description": {
          "type": "string",
          "example": "Hands-on coding challenge with mentor support and prizes."
        }
      }
    },
    "Organizer": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Tech Club"
        },
        "email": {
          "type": "string",
          "example": "techclub@university.edu"
        },
        "phone": {
          "type": "string",
          "example": "555-123-4567"
        }
      }
    },
    "Venue": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Innovation Hall"
        },
        "building": {
          "type": "string",
          "example": "Science Complex"
        },
        "capacity": {
          "type": "number",
          "example": 180
        }
      }
    },
    "Registration": {
      "type": "object",
      "properties": {
        "eventId": {
          "type": "string",
          "example": "6801234567890abcde123456"
        },
        "attendeeName": {
          "type": "string",
          "example": "Jane Doe"
        },
        "attendeeEmail": {
          "type": "string",
          "example": "jane.doe@school.edu"
        },
        "status": {
          "type": "string",
          "example": "registered"
        }
      }
    }
  }
